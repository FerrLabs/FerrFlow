{
  "meta": {
    "name": "skip-ci-commit",
    "description": "skipCi config appends [skip ci] to release commit message"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"skipCi\": true\n  },\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    { "name": "myapp", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: add notifications", "files": ["src/notify.rs"] }
  ],
  "expect": {
    "check_contains": ["myapp", "1.1.0"],
    "check_not_contains": ["Nothing to release"]
  }
}
