{
  "meta": {
    "name": "changelog-scoped",
    "description": "Scoped commits are grouped by scope in the changelog"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\"name\": \"app\", \"path\": \".\", \"changelog\": \"CHANGELOG.md\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]}\n  ]\n}\n"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat(parser): add streaming support", "files": ["src/parser.rs"] },
    { "message": "feat(api): add health endpoint", "files": ["src/api.rs"] },
    { "message": "fix(parser): handle EOF", "files": ["src/parser.rs"] }
  ],
  "expect": {
    "check_contains": ["app", "1.1.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
