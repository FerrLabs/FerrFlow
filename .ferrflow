{
  "workspace": {
    "remote": "origin",
    "branch": "main",
    "tag_template": "v{version}"
  },
  "package": [
    {
      "name": "ferrflow",
      "path": ".",
      "changelog": "CHANGELOG.md",
      "shared_paths": ["src/"],
      "versioned_files": [
        { "path": "Cargo.toml", "format": "toml" },
        { "path": "npm/package.json", "format": "json" }
      ]
    }
  ]
}
