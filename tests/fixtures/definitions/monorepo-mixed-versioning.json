{
  "meta": {
    "name": "monorepo-mixed-versioning",
    "description": "Monorepo with different versioning strategies per package"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"versioning\": \"semver\"\n  },\n  \"package\": [\n    {\n      \"name\": \"api\",\n      \"path\": \"api\",\n      \"versioning\": \"semver\",\n      \"versioned_files\": [{\"path\": \"api/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"sdk\",\n      \"path\": \"sdk\",\n      \"versioning\": \"zerover\",\n      \"versioned_files\": [{\"path\": \"sdk/version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    { "name": "api", "path": "api", "initial_version": "2.0.0", "tag": "api@v2.0.0" },
