{
  "meta": {
    "name": "multi-versioned-files",
    "description": "Single package with multiple versioned files all using toml format"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [\n        {\"path\": \"version.toml\", \"format\": \"toml\"},\n        {\"path\": \"version2.toml\", \"format\": \"toml\"}\n      ]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0"
    }
  ],
  "commits": [
    { "message": "feat: add multi-format support", "files": ["src/main.rs"] }
  ],
  "expect": {
    "check_contains": ["myapp", "1.1.0", "minor"],
    "check_not_contains": ["Nothing to release"]
  }
}
