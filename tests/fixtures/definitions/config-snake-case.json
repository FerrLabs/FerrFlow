{
  "meta": {
    "name": "config-snake-case",
    "description": "Config using snake_case keys works as alias for camelCase"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"tag_template\": \"v{version}\",\n    \"floating_tags\": [\"major\"],\n    \"release_commit_mode\": \"commit\"\n  },\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    { "name": "myapp", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: test snake_case config", "files": ["src/main.rs"] }
  ],
  "expect": {
    "check_contains": ["myapp", "1.1.0", "floating tag"],
    "check_not_contains": ["Nothing to release"]
  }
}
