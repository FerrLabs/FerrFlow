{
  "meta": {
    "name": "tag-name-at-version",
    "description": "Monorepo tag template using {name}@v{version} format"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"tagTemplate\": \"{name}@v{version}\"\n  },\n  \"package\": [\n    {\"name\": \"core\", \"path\": \"core\", \"versioned_files\": [{\"path\": \"core/version.toml\", \"format\": \"toml\"}]}\n  ]\n}\n"
  },
  "packages": [
    { "name": "core", "path": "core", "initial_version": "1.0.0", "tag": "core@v1.0.0" }
  ],
  "commits": [
    { "message": "feat(core): new feature", "files": ["core/src/lib.rs"] }
  ],
  "expect": {
    "check_contains": ["core", "1.1.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
