{
  "meta": {
    "name": "monorepo-breaking",
    "description": "Breaking change in one monorepo package triggers a major bump"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\"name\": \"core\", \"path\": \"core\", \"versioned_files\": [{\"path\": \"core/version.toml\", \"format\": \"toml\"}]},\n    {\"name\": \"cli\", \"path\": \"cli\", \"versioned_files\": [{\"path\": \"cli/version.toml\", \"format\": \"toml\"}]}\n  ]\n}\n"
  },
  "packages": [
    { "name": "core", "path": "core", "initial_version": "1.2.0", "tag": "core@v1.2.0" },
    { "name": "cli", "path": "cli", "initial_version": "1.0.0", "tag": "cli@v1.0.0" }
  ],
  "commits": [
    {
      "message": "feat!: redesign API and update CLI",
      "files": ["core/src/lib.rs", "cli/src/main.rs"]
    }
  ],
  "expect": {
    "check_contains": ["core", "2.0.0", "cli", "2.0.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 2
  }
}
