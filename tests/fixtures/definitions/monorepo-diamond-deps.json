{
  "meta": {
    "name": "monorepo-diamond-deps",
    "description": "Diamond dependency: app depends on api and cli, both depend on core"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"core\",\n      \"path\": \"core\",\n      \"versioned_files\": [{\"path\": \"core/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"api\",\n      \"path\": \"api\",\n      \"dependsOn\": [\"core\"],\n      \"versioned_files\": [{\"path\": \"api/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"cli\",\n      \"path\": \"cli\",\n      \"dependsOn\": [\"core\"],\n      \"versioned_files\": [{\"path\": \"cli/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"app\",\n      \"path\": \"app\",\n      \"dependsOn\": [\"api\", \"cli\"],\n      \"versioned_files\": [{\"path\": \"app/version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    { "name": "core", "path": "core", "initial_version": "1.0.0", "tag": "core@v1.0.0" },
    { "name": "api", "path": "api", "initial_version": "1.0.0", "tag": "api@v1.0.0" },
    { "name": "cli", "path": "cli", "initial_version": "1.0.0", "tag": "cli@v1.0.0" },
    { "name": "app", "path": "app", "initial_version": "1.0.0", "tag": "app@v1.0.0" }
  ],
