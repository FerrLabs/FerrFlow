{
  "meta": {
    "name": "hooks-package-override",
    "description": "Package-level hooks override workspace-level hooks"
  },
  "config": {
    "content": "{\n  \"workspace\": {\n    \"hooks\": {\n      \"preBump\": \"echo workspace-hook\"\n    }\n  },\n  \"package\": [\n    {\n      \"name\": \"core\",\n      \"path\": \"core\",\n      \"hooks\": {\n        \"preBump\": \"echo core-hook\"\n      },\n      \"versioned_files\": [{\"path\": \"core/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"web\",\n      \"path\": \"web\",\n      \"versioned_files\": [{\"path\": \"web/version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    { "name": "core", "path": "core", "initial_version": "1.0.0", "tag": "core@v1.0.0" },
    { "name": "web", "path": "web", "initial_version": "1.0.0", "tag": "web@v1.0.0" }
  ],
  "commits": [
    { "message": "feat: update both", "files": ["core/src/lib.rs", "web/src/app.rs"] }
  ],
  "expect": {
    "check_contains": ["core", "1.1.0", "web", "1.1.0"],
    "check_not_contains": ["Nothing to release"]
  }
}
