{
  "meta": {
    "name": "changelog-breaking",
    "description": "Breaking changes appear in a dedicated section of the changelog"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\"name\": \"app\", \"path\": \".\", \"changelog\": \"CHANGELOG.md\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}]}\n  ]\n}\n"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat!: remove deprecated API", "files": ["src/main.rs"] },
    { "message": "fix: handle edge case", "files": ["src/lib.rs"] }
  ],
  "expect": {
    "check_contains": ["app", "2.0.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
