{
  "meta": {
    "name": "changelog-monorepo-per-package",
    "description": "Monorepo with per-package changelog files"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"api\",\n      \"path\": \"api\",\n      \"changelog\": \"api/CHANGELOG.md\",\n      \"versioned_files\": [{\"path\": \"api/version.toml\", \"format\": \"toml\"}]\n    },\n    {\n      \"name\": \"sdk\",\n      \"path\": \"sdk\",\n      \"changelog\": \"sdk/CHANGELOG.md\",\n      \"versioned_files\": [{\"path\": \"sdk/version.toml\", \"format\": \"toml\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    { "name": "api", "path": "api", "initial_version": "1.0.0", "tag": "api@v1.0.0" },
    { "name": "sdk", "path": "sdk", "initial_version": "1.0.0", "tag": "sdk@v1.0.0" }
  ],
  "commits": [
    {
      "message": "feat: add rate limiting and improve retry logic",
      "files": ["api/src/ratelimit.rs", "sdk/src/retry.rs"]
    }
  ],
  "expect": {
    "check_contains": ["api", "1.1.0", "sdk", "1.1.0"],
    "check_not_contains": ["Nothing to release"]
  }
}
